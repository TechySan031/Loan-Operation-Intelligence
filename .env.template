# ============================================================
# Loan Operation Intelligence — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=loi_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=loan_operation_intelligence
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_MODEL_MINI=gpt-4o-mini

# --- Pinecone ---
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=loan-kb
PINECONE_ENVIRONMENT=us-east-1

# --- Vapi.ai (Voice Platform) ---
VAPI_API_KEY=...
VAPI_ASSISTANT_ID_EN=...
VAPI_ASSISTANT_ID_PH=...
VAPI_ASSISTANT_ID_ID=...
VAPI_PHONE_NUMBER_ID=...
VAPI_WEBHOOK_SECRET=...
VAPI_SERVER_URL=https://your-domain.com/api/voice/webhook

# --- Deepgram (Streaming ASR for Q4) ---
DEEPGRAM_API_KEY=...

# --- Langfuse (Observability) ---
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Google Cloud (Multilingual TTS/ASR for Q3) ---
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# --- PII Detection ---
PII_DETECTION_ENABLED=true
PII_DETECTION_THRESHOLD=0.7
